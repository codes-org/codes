# Files clang-format should never touch. clang-format 18+ honors this
# file natively (same syntax as .gitignore — one path per line, comments
# begin with `#`).

# Generated by FLEX / BISON at build time from configlex.l and
# configparser.y (see src/CMakeLists.txt). The generator's output
# layout — not clang-format's — is authoritative for these files;
# enforcing clang-format on them would force a re-format on every
# build that regenerates them.
#
# Longer term, these should be generated into the build directory
# (CMAKE_CURRENT_BINARY_DIR) instead of polluting the source tree,
# at which point this exclusion goes away.
